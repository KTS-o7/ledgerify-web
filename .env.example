# Ledgerify Go Server — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# Server
PORT=8080
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://ledgerify:password@localhost:5432/ledgerify?sslmode=disable

# JWT (required — min 32 chars, generate with: openssl rand -base64 32)
JWT_SECRET=
JWT_ISSUER=ledgerify

# LLM — taalas-llama3.1-8b self-hosted API
# Leave LLM_API_KEY empty to disable LLM entirely (keyword-only categorization)
LLM_API_URL=https://ai.shenthar.me
LLM_API_KEY=
LLM_MODEL=taalas-llama3.1-8b
LLM_USER_AGENT=curl/8.4.0
LLM_WORKERS=3
LLM_QUEUE_SIZE=100
